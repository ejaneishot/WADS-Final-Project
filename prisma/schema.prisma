//prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  student
  admin
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  role         Role     @default(student)
  createdAt    DateTime @default(now())

  profile Profile?

  assessmentAttempts AssessmentAttempt[]
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String?
  major     String?
  semester  Int?
  gpaRange  String?
  interests String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills UserSkill[]
}

model Skill {
  id       String @id @default(cuid())
  name     String @unique
  category String

  users UserSkill[]
}

model UserSkill {
  id        String @id @default(cuid())
  profileId String
  skillId   String
  level     Int

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([profileId, skillId])
}

model Career {
  id          String   @id @default(cuid())
  title       String
  industry    String
  description String
  createdAt   DateTime @default(now())
}

// Core quiz content only: quizzes -> sections -> questions -> options
// No user answers / attempts here.

model Quiz {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  description String?
  isActive    Boolean @default(true)

  // Ordering / versioning-ish
  version Int @default(1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sections           QuizSection[]
  questions          QuizQuestion[] // optional: direct questions without sections
  assessmentAttempts AssessmentAttempt[]
}

model QuizSection {
  id          String  @id @default(cuid())
  quizId      String
  title       String
  description String?
  order       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quiz      Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]

  @@unique([quizId, order])
  @@index([quizId])
}

enum QuestionType {
  SINGLE_CHOICE
  // You can add later:
  // MULTI_CHOICE
  // SCALE
  // TEXT
}

model QuizQuestion {
  id        String  @id @default(cuid())
  quizId    String
  sectionId String?

  prompt     String
  helperText String?
  type       QuestionType @default(SINGLE_CHOICE)

  // order within section if sectionId is set,
  // otherwise order within quiz (for unsectioned questions)
  order Int @default(0)

  isRequired Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quiz              Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  section           QuizSection?       @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  options           QuizOption[]
  assessmentAnswers AssessmentAnswer[]

  @@unique([quizId, sectionId, order])
  @@index([quizId])
  @@index([sectionId])
}

model QuizOption {
  id         String @id @default(cuid())
  questionId String

  label String // e.g. "Solving logic puzzles..."
  value String? // optional stable key like "A", "B", "logic_puzzles"
  order Int     @default(0)

  // Optional: store scoring hints / tags per option as JSON.
  // Example JSON:
  // [{"tag":"SWE","weight":2},{"tag":"AI","weight":1}]
  scoring Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  question          QuizQuestion       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  assessmentAnswers AssessmentAnswer[]

  @@unique([questionId, order])
  @@index([questionId])
}

// User answers to questions

model AssessmentAttempt {
  id     String @id @default(cuid())
  userId String
  quizId String

  // computed result snapshot
  scores    Json // { "SWE": 5, "FE": 2, ... }
  primary   String // e.g. "BE"
  secondary String? // e.g. "SWE"

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  answers AssessmentAnswer[]

  @@index([userId])
  @@index([quizId])
}

model AssessmentAnswer {
  id         String @id @default(cuid())
  attemptId  String
  questionId String
  optionId   String

  attempt  AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option   QuizOption        @relation(fields: [optionId], references: [id], onDelete: Cascade)

  // Prevent duplicate answers for the same question in the same attempt
  @@unique([attemptId, questionId])
  @@index([questionId])
  @@index([optionId])
}
