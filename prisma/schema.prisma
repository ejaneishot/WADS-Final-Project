// Career Compass — PostgreSQL schema (Prisma 7).
// Auth users, profiles/skills, career catalog, learning roadmaps, and the built-in career matcher quiz.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  student
  admin
}

/// Application account; optional password when using OAuth-only flows.
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  role         Role     @default(student)
  createdAt    DateTime @default(now())

  profile Profile?

  assessmentAttempts AssessmentAttempt[]

  roadmaps Roadmap[]

  careerProgress UserCareerProgress[]
}

/// Extended student info and skill ratings (1:1 with User).
model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String?
  major     String?
  semester  Int?
  /// Display bucket, e.g. "3.5–3.75", not a computed GPA.
  gpaRange  String?
  interests String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills UserSkill[]
}

/// Canonical skill catalog referenced by profiles.
model Skill {
  id       String @id @default(cuid())
  name     String @unique
  category String

  users UserSkill[]
}

/// Self-reported proficiency for a skill on a profile (unique per profile + skill).
model UserSkill {
  id        String @id @default(cuid())
  profileId String
  skillId   String
  level     Int

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([profileId, skillId])
}

/// Career path shown in the UI; slug matches seed/API routes, tag drives quiz scoring.
model Career {
  id          String   @id @default(cuid())
  slug        String   @unique
  /// Short code used in assessment scoring (e.g. SWE, FE) — unique across careers.
  tag         String   @unique
  title       String
  industry    String
  description String

  /// Tailwind-oriented presentation tokens (see prisma/seed.ts).
  icon       String?
  color      String?
  gradient   String?
  border     String?
  milestones String[] @default([])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userProgress UserCareerProgress[]
}

/// Per-user checklist state for career milestone steps (see /api/careers).
model UserCareerProgress {
  id                  String   @id @default(cuid())
  userId              String
  careerId            String
  completedMilestones Int[]    @default([])
  updatedAt           DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  career Career @relation(fields: [careerId], references: [id], onDelete: Cascade)

  @@unique([userId, careerId])
  @@index([userId])
  @@index([careerId])
}

/// User-owned learning path graph (nodes linked via RoadmapEdge).
model Roadmap {
  id        String        @id @default(cuid())
  title     String
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  nodes     RoadmapNode[]
  createdAt DateTime      @default(now())
}

model RoadmapNode {
  id          String   @id @default(cuid())
  title       String
  description String?
  roadmapId   String
  roadmap     Roadmap  @relation(fields: [roadmapId], references: [id])

  parents  RoadmapEdge[] @relation("ChildToParent")
  children RoadmapEdge[] @relation("ParentToChild")
}

/// Directed prerequisite edge: parent must precede child in the roadmap DAG.
model RoadmapEdge {
  parentId String
  childId  String

  parent RoadmapNode @relation("ParentToChild", fields: [parentId], references: [id])
  child  RoadmapNode @relation("ChildToParent", fields: [childId], references: [id])

  @@id([parentId, childId])
}

// --- Career matcher quiz (single assessment; no quiz catalog table) ---

/// Grouped block of questions in the matcher (order is unique across sections).
model QuizSection {
  id          String  @id @default(cuid())
  title       String
  description String?
  order       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions QuizQuestion[]

  @@unique([order])
}

enum QuestionType {
  SINGLE_CHOICE
  // MULTI_CHOICE | SCALE | TEXT — reserved for future question types
}

model QuizQuestion {
  id        String  @id @default(cuid())
  /// Null only for legacy/unsectioned items; seed always sets sectionId.
  sectionId String?

  prompt     String
  helperText String?
  type       QuestionType @default(SINGLE_CHOICE)

  /// Sort key within section (or global order when sectionId is null).
  order Int @default(0)

  isRequired Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section           QuizSection?       @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  options           QuizOption[]
  assessmentAnswers AssessmentAnswer[]

  @@unique([sectionId, order])
  @@index([sectionId])
}

model QuizOption {
  id         String @id @default(cuid())
  questionId String

  label String
  /// Stable answer key for analytics/API (e.g. "A", "logic_puzzles").
  value String?
  order Int     @default(0)

  /// Per-tag weights summed on submit, e.g. [{"tag":"SWE","weight":2}].
  scoring Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  question          QuizQuestion       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  assessmentAnswers AssessmentAnswer[]

  @@unique([questionId, order])
  @@index([questionId])
}

// --- Submitted assessment runs and per-question answers ---

/// One completed (or in-progress) quiz submission with denormalized match results.
model AssessmentAttempt {
  id     String @id @default(cuid())
  userId String

  /// Tag → total weight after scoring all answers, e.g. { "SWE": 5, "FE": 2 }.
  scores    Json
  /// Top Career.tag from scores.
  primary   String
  secondary String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  answers AssessmentAnswer[]

  @@index([userId])
}

/// One selected option per question per attempt (enforced by @@unique below).
model AssessmentAnswer {
  id         String @id @default(cuid())
  attemptId  String
  questionId String
  optionId   String

  attempt  AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option   QuizOption        @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
  @@index([questionId])
  @@index([optionId])
}
