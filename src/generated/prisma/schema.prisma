//prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  student
  admin
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  role         Role     @default(student)
  createdAt    DateTime @default(now())

  profile Profile?

  assessmentAttempts AssessmentAttempt[]

  roadmaps Roadmap[]

  careerProgress UserCareerProgress[]
}

model Profile {
  id        String   @id @default(cuid())
  userId    String   @unique
  name      String?
  major     String?
  semester  Int?
  gpaRange  String?
  interests String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  skills UserSkill[]
}

model Skill {
  id       String @id @default(cuid())
  name     String @unique
  category String

  users UserSkill[]
}

model UserSkill {
  id        String @id @default(cuid())
  profileId String
  skillId   String
  level     Int

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skill   Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([profileId, skillId])
}

model Career {
  id          String @id @default(cuid())
  slug        String @unique // Added: consistent with careersData
  title       String
  industry    String
  description String

  // Added fields from seed.ts
  icon       String? // e.g., "💻"
  color      String? // e.g., "from-blue-500 to-cyan-500"
  gradient   String? // e.g., "from-blue-500/20 to-cyan-500/20"
  border     String? // e.g., "rgba(59,130,246,0.2)"
  milestones String[] @default([]) // Array of roadmap steps

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userProgress UserCareerProgress[]
}

/// Per-user checklist state for career milestone steps (see /api/careers).
model UserCareerProgress {
  id                  String   @id @default(cuid())
  userId              String
  careerId            String
  completedMilestones Int[]    @default([])
  updatedAt           DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  career Career @relation(fields: [careerId], references: [id], onDelete: Cascade)

  @@unique([userId, careerId])
  @@index([userId])
  @@index([careerId])
}

model Roadmap {
  id        String        @id @default(cuid())
  title     String
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  nodes     RoadmapNode[]
  createdAt DateTime      @default(now())
}

model RoadmapNode {
  id          String  @id @default(cuid())
  title       String
  description String?
  roadmapId   String
  roadmap     Roadmap @relation(fields: [roadmapId], references: [id])

  parents  RoadmapEdge[] @relation("ChildToParent")
  children RoadmapEdge[] @relation("ParentToChild")
}

model RoadmapEdge {
  parentId String
  childId  String

  parent RoadmapNode @relation("ParentToChild", fields: [parentId], references: [id])
  child  RoadmapNode @relation("ChildToParent", fields: [childId], references: [id])

  @@id([parentId, childId])
}

// Core assessment content only: sections -> questions -> options.
// Single built-in assessment definition (no quiz catalog table).

model QuizSection {
  id          String  @id @default(cuid())
  title       String
  description String?
  order       Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions QuizQuestion[]

  @@unique([order])
}

enum QuestionType {
  SINGLE_CHOICE
  // You can add later:
  // MULTI_CHOICE
  // SCALE
  // TEXT
}

model QuizQuestion {
  id        String  @id @default(cuid())
  sectionId String?

  prompt     String
  helperText String?
  type       QuestionType @default(SINGLE_CHOICE)

  // order within section if sectionId is set,
  // otherwise order within the single assessment (for unsectioned questions)
  order Int @default(0)

  isRequired Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section           QuizSection?       @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  options           QuizOption[]
  assessmentAnswers AssessmentAnswer[]

  @@unique([sectionId, order])
  @@index([sectionId])
}

model QuizOption {
  id         String @id @default(cuid())
  questionId String

  label String // e.g. "Solving logic puzzles..."
  value String? // optional stable key like "A", "B", "logic_puzzles"
  order Int     @default(0)

  // Optional: store scoring hints / tags per option as JSON.
  // Example JSON:
  // [{"tag":"SWE","weight":2},{"tag":"AI","weight":1}]
  scoring Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  question          QuizQuestion       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  assessmentAnswers AssessmentAnswer[]

  @@unique([questionId, order])
  @@index([questionId])
}

// User answers to questions

model AssessmentAttempt {
  id     String @id @default(cuid())
  userId String

  // computed result snapshot
  scores    Json // { "SWE": 5, "FE": 2, ... }
  primary   String // e.g. "BE"
  secondary String? // e.g. "SWE"

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  answers AssessmentAnswer[]

  @@index([userId])
}

model AssessmentAnswer {
  id         String @id @default(cuid())
  attemptId  String
  questionId String
  optionId   String

  attempt  AssessmentAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion      @relation(fields: [questionId], references: [id], onDelete: Cascade)
  option   QuizOption        @relation(fields: [optionId], references: [id], onDelete: Cascade)

  // Prevent duplicate answers for the same question in the same attempt
  @@unique([attemptId, questionId])
  @@index([questionId])
  @@index([optionId])
}
